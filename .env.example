# ── InSync Tech ARIA Intake Pipeline — Environment Variables ──────────────────
# Copy this to .env for local testing. Set all values in Railway dashboard for prod.

# Webhook security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTAKE_WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic — same key as Mel pipeline
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs — same key as Mel pipeline
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Resend — same key as Mel pipeline
RESEND_API_KEY=your_resend_api_key_here

# Email routing
FROM_EMAIL=intake@insynctech.io
INSYNC_INBOX=ian@insynctech.io

# Railway auto-sets PORT — do not set manually in prod
PORT=8001

# Follow-up SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FOLLOWUP_NUMBER=+1XXXXXXXXXX  # dedicated InSync Tech outbound number

# Follow-up email from address
FOLLOWUP_FROM_EMAIL=hello@insynctech.io

# Default business name if not in webhook payload
DEFAULT_BUSINESS_NAME=InSync Tech
